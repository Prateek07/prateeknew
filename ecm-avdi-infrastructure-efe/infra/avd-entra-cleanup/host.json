{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.0.0, 5.0.0)"
  },
  "managedDependency": {
    "enabled": true
  },
  "logging": {
    "logLevel": {
      "default": "Information",
      "Function.AvdEntraCleanup": "Information"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true
      }
    }
  },
  "functionTimeout": "00:10:00"
}
